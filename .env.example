# Database
DATABASE_URL="postgresql://trp:trp@localhost:5432/trp?schema=public"

# API
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Auth (JWT) — change JWT_SECRET before any shared/deployed environment
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="8h"

# Seed / development identity credentials
SEED_USER_EMAIL="admin@trp.local"
SEED_USER_PASSWORD="trp-admin-change-me"

# Inbound API rate limiting
API_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW="1 minute"
API_THROTTLE_TTL_MS=60000
API_THROTTLE_LIMIT=200

# Market Data Domain — active live provider: mock | binance (default: mock)
MARKET_DATA_PROVIDER="mock"

# Market Data Cache (US008) — in-memory TTL cache between controller and provider
MARKET_CACHE_ENABLED=true
MARKET_CACHE_TICKER_TTL=5
MARKET_CACHE_CANDLES_TTL=60

# AI Gateway (optional — offline summary if unset)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Web (Vite)
VITE_API_URL=http://localhost:3000
