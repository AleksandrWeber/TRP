{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "CI",
    "DATABASE_URL",
    "JWT_SECRET",
    "NODE_ENV",
    "CORS_ORIGIN",
    "API_PORT",
    "API_HOST"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["DATABASE_URL", "JWT_SECRET", "CI"],
      "env": ["DATABASE_URL", "JWT_SECRET", "CI"]
    }
  }
}
