generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRATOR
  RESEARCHER
  TRADER
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(RESEARCHER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Dataset {
  id          String       @id @default(cuid())
  symbol      String
  timeframe   String
  exchange    String       @default("binance")
  contentHash String       @unique
  barCount    Int
  startTime   DateTime
  endTime     DateTime
  gitCommit   String?
  createdAt   DateTime     @default(now())
  bars        OhlcvBar[]
  experiments Experiment[]

  @@index([symbol, timeframe])
}

model OhlcvBar {
  id        String   @id @default(cuid())
  datasetId String
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  dataset   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, timestamp])
  @@index([datasetId, timestamp])
}

model Experiment {
  id              String              @id @default(cuid())
  datasetId       String
  strategyId      String
  strategyVersion String
  configHash      String
  gitCommit       String?
  verdict         String
  report          Json
  metrics         Json
  validation      Json
  trades          Json
  createdAt       DateTime            @default(now())
  dataset         Dataset             @relation(fields: [datasetId], references: [id])
  deployment      StrategyDeployment?
  knowledge       KnowledgeEntry[]

  @@index([datasetId])
  @@index([createdAt])
  @@index([verdict])
}

model StrategyDeployment {
  id              String              @id @default(cuid())
  experimentId    String              @unique
  strategyId      String
  strategyVersion String
  symbol          String
  timeframe       String
  exchange        String              @default("binance")
  mode            String              @default("paper")
  status          String              @default("active")
  approvedAt      DateTime            @default(now())
  gitCommit       String?
  experiment      Experiment          @relation(fields: [experimentId], references: [id])
  position        ProductionPosition?
  signals         Signal[]
  executions      Execution[]

  @@index([status])
  @@index([symbol, timeframe])
}

model ProductionPosition {
  id           String             @id @default(cuid())
  deploymentId String             @unique
  side         String             @default("flat")
  quantity     Float              @default(0)
  entryPrice   Float?
  updatedAt    DateTime           @updatedAt
  deployment   StrategyDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model Signal {
  id           String             @id @default(cuid())
  deploymentId String
  type         String
  price        Float
  timestamp    DateTime
  actedOn      Boolean            @default(false)
  createdAt    DateTime           @default(now())
  deployment   StrategyDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  execution    Execution?

  @@index([deploymentId, createdAt])
}

model Execution {
  id           String             @id @default(cuid())
  deploymentId String
  signalId     String             @unique
  symbol       String
  side         String
  quantity     Float
  price        Float
  fee          Float
  mode         String             @default("paper")
  status       String
  rejectReason String?
  executedAt   DateTime           @default(now())
  deployment   StrategyDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  signal       Signal             @relation(fields: [signalId], references: [id])

  @@index([deploymentId, executedAt])
}

model Workflow {
  id          String             @id @default(cuid())
  type        String
  status      String             @default("pending")
  context     Json
  error       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  completedAt DateTime?
  steps       WorkflowStep[]
  knowledge   KnowledgeEntry[]

  @@index([status])
  @@index([createdAt])
}

model WorkflowStep {
  id          String    @id @default(cuid())
  workflowId  String
  name        String
  stepOrder   Int
  status      String    @default("pending")
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, stepOrder])
}

model KnowledgeEntry {
  id               String      @id @default(cuid())
  type             String
  title            String
  description      String
  category         String
  tags             String[]
  version          Int         @default(1)
  parentId         String?
  validationStatus String
  workflowId       String?
  experimentId     String?
  authorEmail      String?
  payload          Json
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  workflow         Workflow?   @relation(fields: [workflowId], references: [id])
  experiment       Experiment? @relation(fields: [experimentId], references: [id])

  @@index([type])
  @@index([category])
  @@index([createdAt])
}

model DomainEventLog {
  id            String   @id @default(cuid())
  type          String
  correlationId String?
  payload       Json
  createdAt     DateTime @default(now())

  @@index([type, createdAt])
}

model AiRequestLog {
  id         String   @id @default(cuid())
  task       String
  provider   String
  model      String
  success    Boolean
  durationMs Int
  error      String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

/// Research OS domain persistence (US104) — JSON payload mirrors domain aggregates.
/// Distinct from legacy KnowledgeEntry (research_outcome / workflow knowledge).

model ResearchCampaignRecord {
  id      String @id
  payload Json

  @@map("research_campaign_records")
}

model ResearchDomainKnowledge {
  knowledgeId  String @id @map("knowledge_id")
  experimentId String @unique @map("experiment_id")
  payload      Json

  @@map("research_domain_knowledge")
}

model ResearchInsight {
  id      String @id
  payload Json

  @@map("research_insights")
}

model ResearchRecommendation {
  id      String @id
  payload Json

  @@map("research_recommendations")
}

model ResearchReportAggregate {
  id      String @id
  payload Json

  @@map("research_report_aggregates")
}

/// RC-16 ADR-013 durable Outbox (US128). Envelope immutable; delivery metadata mutable.
enum OutboxDeliveryStatus {
  pending
  publishing
  published
  dead_letter
}

model OutboxEvent {
  eventId          String              @id @map("event_id")
  eventType        String              @map("event_type")
  schemaVersion    Int                 @map("schema_version")
  aggregateType    String              @map("aggregate_type")
  aggregateId      String              @map("aggregate_id")
  aggregateVersion Int                 @map("aggregate_version")
  workspaceId      String              @map("workspace_id")
  occurredAt       DateTime            @map("occurred_at")
  recordedAt       DateTime            @map("recorded_at")
  correlationId    String?             @map("correlation_id")
  causationId      String?             @map("causation_id")
  actorId          String?             @map("actor_id")
  payload          Json
  status           OutboxDeliveryStatus @default(pending)
  attempts         Int                 @default(0)
  lastError        String?             @map("last_error")
  nextAttemptAt    DateTime?           @map("next_attempt_at")
  publishedAt      DateTime?           @map("published_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@unique([aggregateType, aggregateId, aggregateVersion])
  @@index([workspaceId, status, createdAt])
  @@index([status, nextAttemptAt, createdAt])
  @@map("outbox_events")
}

/// RC-16 ADR-013 consumer Inbox (US129). Unique (consumerId, eventId).
model InboxRecord {
  consumerId      String   @map("consumer_id")
  eventId         String   @map("event_id")
  consumerVersion String   @map("consumer_version")
  processedAt     DateTime @map("processed_at")

  @@id([consumerId, eventId])
  @@index([eventId])
  @@map("inbox_records")
}

enum ConsumerCheckpointDeliveryStatus {
  ready
  blocked_gap
  error
}

/// RC-16 ADR-013 consumer checkpoints (US129).
model ConsumerCheckpointRecord {
  consumerId           String                          @map("consumer_id")
  streamId             String                          @map("stream_id")
  consumerVersion      String                          @map("consumer_version")
  workspaceId          String                          @map("workspace_id")
  lastAppliedSequence  Int                             @map("last_applied_sequence")
  lastAppliedEventId   String?                         @map("last_applied_event_id")
  status               ConsumerCheckpointDeliveryStatus @default(ready)
  blockedSequence      Int?                            @map("blocked_sequence")
  lastError            String?                         @map("last_error")
  updatedAt            DateTime                        @updatedAt @map("updated_at")

  @@id([consumerId, streamId])
  @@index([workspaceId, consumerId])
  @@map("consumer_checkpoints")
}
