generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRATOR
  RESEARCHER
  TRADER
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(RESEARCHER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


/// Durable Workspace aggregate and ownership boundary (RC-16 Foundations / US002).
model WorkspaceRecord {
  id          String   @id
  name        String
  ownerUserId String   @map("owner_user_id")
  status      String
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([ownerUserId, status])
  @@map("workspace_records")
}

/// Workspace-owned Strategy definition (US004) with trading configuration (US005).
model StrategyRecord {
  id                String   @id
  workspaceId       String   @map("workspace_id")
  name              String
  description       String
  status            String
  tradingPair       String   @map("trading_pair")
  timeframe         String
  direction         String
  positionSize      Float    @map("position_size")
  stopLossPercent   Float    @map("stop_loss_percent")
  takeProfitPercent Float    @map("take_profit_percent")
  parameters        Json
  createdAt         DateTime @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, tradingPair, timeframe])
  @@map("strategy_records")
}

model Dataset {
  id                String                     @id @default(cuid())
  displayName       String                     @default("")
  description       String                     @default("")
  marketRegime      String                     @default("UNCLASSIFIED")
  symbol            String
  symbols           String[]                   @default([])
  timeframe         String
  exchange          String                     @default("binance")
  enabled           Boolean                    @default(true)
  contentHash       String                     @unique
  barCount          Int
  startTime         DateTime
  endTime           DateTime
  gitCommit         String?
  createdAt         DateTime                   @default(now())
  bars              OhlcvBar[]
  experiments       Experiment[]
  historicalResults HistoricalResearchResult[]

  @@index([symbol, timeframe])
  @@index([enabled, marketRegime])
}

model OhlcvBar {
  id        String   @id @default(cuid())
  datasetId String
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  dataset   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, timestamp])
  @@index([datasetId, timestamp])
}

model Experiment {
  id              String              @id @default(cuid())
  datasetId       String
  strategyId      String
  strategyVersion String
  configHash      String
  gitCommit       String?
  verdict         String
  report          Json
  metrics         Json
  validation      Json
  trades          Json
  createdAt       DateTime            @default(now())
  dataset         Dataset             @relation(fields: [datasetId], references: [id])
  deployment      StrategyDeployment?
  knowledge       KnowledgeEntry[]

  @@index([datasetId])
  @@index([createdAt])
  @@index([verdict])
}

/// One immutable Historical Research invocation (US018).
/// Every invocation receives a new id; completed results are never overwritten.
model HistoricalResearchRun {
  id          String                     @id
  workspaceId String                     @map("workspace_id")
  status      String
  datasetIds  Json                       @map("dataset_ids")
  strategyIds Json                       @map("strategy_ids")
  report      Json?
  failure     String?
  startedAt   DateTime                   @map("started_at")
  completedAt DateTime?                  @map("completed_at")
  results     HistoricalResearchResult[]

  @@index([workspaceId, startedAt])
  @@index([workspaceId, status])
  @@map("historical_research_runs")
}

/// Immutable Strategy × Dataset × Market Regime result (US018).
/// Scalar metrics are queryable for a future regime-performance matrix.
model HistoricalResearchResult {
  id                 String                @id
  researchId         String                @map("research_id")
  workspaceId        String                @map("workspace_id")
  datasetId          String                @map("dataset_id")
  datasetName        String                @map("dataset_name")
  datasetContentHash String                @map("dataset_content_hash")
  marketRegime       String                @map("market_regime")
  strategyId         String                @map("strategy_id")
  strategyName       String                @map("strategy_name")
  strategySnapshot   Json                  @map("strategy_snapshot")
  exchange           String
  symbol             String
  timeframe          String
  status             String
  failure            String?
  trades             Json
  tradeCount         Int                   @map("trade_count")
  winRate            Float                 @map("win_rate")
  netProfit          Float                 @map("net_profit")
  profitFactor       Float                 @map("profit_factor")
  maxDrawdown        Float                 @map("max_drawdown")
  executionTimeMs    Int                   @map("execution_time_ms")
  validation         Json
  resultHash         String                @map("result_hash")
  createdAt          DateTime              @map("created_at")
  research           HistoricalResearchRun @relation(fields: [researchId], references: [id], onDelete: Restrict)
  dataset            Dataset               @relation(fields: [datasetId], references: [id], onDelete: Restrict)

  @@unique([researchId, datasetId, strategyId, symbol])
  @@index([workspaceId, strategyId, marketRegime])
  @@index([workspaceId, datasetId])
  @@index([workspaceId, createdAt])
  @@map("historical_research_results")
}

model StrategyDeployment {
  id              String              @id @default(cuid())
  experimentId    String              @unique
  strategyId      String
  strategyVersion String
  symbol          String
  timeframe       String
  exchange        String              @default("binance")
  mode            String              @default("paper")
  status          String              @default("active")
  approvedAt      DateTime            @default(now())
  gitCommit       String?
  experiment      Experiment          @relation(fields: [experimentId], references: [id])
  position        ProductionPosition?
  signals         Signal[]
  executions      Execution[]

  @@index([status])
  @@index([symbol, timeframe])
}

model ProductionPosition {
  id           String             @id @default(cuid())
  deploymentId String             @unique
  side         String             @default("flat")
  quantity     Float              @default(0)
  entryPrice   Float?
  updatedAt    DateTime           @updatedAt
  deployment   StrategyDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model Signal {
  id           String             @id @default(cuid())
  deploymentId String
  type         String
  price        Float
  timestamp    DateTime
  actedOn      Boolean            @default(false)
  createdAt    DateTime           @default(now())
  deployment   StrategyDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  execution    Execution?

  @@index([deploymentId, createdAt])
}

model Execution {
  id           String             @id @default(cuid())
  deploymentId String
  signalId     String             @unique
  symbol       String
  side         String
  quantity     Float
  price        Float
  fee          Float
  mode         String             @default("paper")
  status       String
  rejectReason String?
  executedAt   DateTime           @default(now())
  deployment   StrategyDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  signal       Signal             @relation(fields: [signalId], references: [id])

  @@index([deploymentId, executedAt])
}

model Workflow {
  id          String           @id @default(cuid())
  type        String
  status      String           @default("pending")
  context     Json
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  completedAt DateTime?
  steps       WorkflowStep[]
  knowledge   KnowledgeEntry[]

  @@index([status])
  @@index([createdAt])
}

model WorkflowStep {
  id          String    @id @default(cuid())
  workflowId  String
  name        String
  stepOrder   Int
  status      String    @default("pending")
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, stepOrder])
}

model KnowledgeEntry {
  id               String      @id @default(cuid())
  type             String
  title            String
  description      String
  category         String
  tags             String[]
  version          Int         @default(1)
  parentId         String?
  validationStatus String
  workflowId       String?
  experimentId     String?
  authorEmail      String?
  payload          Json
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  workflow         Workflow?   @relation(fields: [workflowId], references: [id])
  experiment       Experiment? @relation(fields: [experimentId], references: [id])

  @@index([type])
  @@index([category])
  @@index([createdAt])
}

model DomainEventLog {
  id            String   @id @default(cuid())
  type          String
  correlationId String?
  payload       Json
  createdAt     DateTime @default(now())

  @@index([type, createdAt])
}

model AiRequestLog {
  id         String   @id @default(cuid())
  task       String
  provider   String
  model      String
  success    Boolean
  durationMs Int
  error      String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

/// Research OS domain persistence (US104) — JSON payload mirrors domain aggregates.
/// Distinct from legacy KnowledgeEntry (research_outcome / workflow knowledge).

model ResearchCampaignRecord {
  id      String @id
  payload Json

  @@map("research_campaign_records")
}

model ResearchDomainKnowledge {
  knowledgeId  String @id @map("knowledge_id")
  experimentId String @unique @map("experiment_id")
  payload      Json

  @@map("research_domain_knowledge")
}

model ResearchInsight {
  id      String @id
  payload Json

  @@map("research_insights")
}

model ResearchRecommendation {
  id      String @id
  payload Json

  @@map("research_recommendations")
}

model ResearchReportAggregate {
  id      String @id
  payload Json

  @@map("research_report_aggregates")
}

/// RC-16 ADR-013 durable Outbox (US128). Envelope immutable; delivery metadata mutable.
enum OutboxDeliveryStatus {
  pending
  publishing
  published
  dead_letter
}

model OutboxEvent {
  eventId          String               @id @map("event_id")
  eventType        String               @map("event_type")
  schemaVersion    Int                  @map("schema_version")
  aggregateType    String               @map("aggregate_type")
  aggregateId      String               @map("aggregate_id")
  aggregateVersion Int                  @map("aggregate_version")
  workspaceId      String               @map("workspace_id")
  occurredAt       DateTime             @map("occurred_at")
  recordedAt       DateTime             @map("recorded_at")
  correlationId    String?              @map("correlation_id")
  causationId      String?              @map("causation_id")
  actorId          String?              @map("actor_id")
  payload          Json
  status           OutboxDeliveryStatus @default(pending)
  attempts         Int                  @default(0)
  lastError        String?              @map("last_error")
  nextAttemptAt    DateTime?            @map("next_attempt_at")
  publishedAt      DateTime?            @map("published_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@unique([aggregateType, aggregateId, aggregateVersion])
  @@index([workspaceId, status, createdAt])
  @@index([status, nextAttemptAt, createdAt])
  @@map("outbox_events")
}

/// RC-16 ADR-013 consumer Inbox (US129). Unique (consumerId, eventId).
model InboxRecord {
  consumerId      String   @map("consumer_id")
  eventId         String   @map("event_id")
  consumerVersion String   @map("consumer_version")
  processedAt     DateTime @map("processed_at")

  @@id([consumerId, eventId])
  @@index([eventId])
  @@map("inbox_records")
}

enum ConsumerCheckpointDeliveryStatus {
  ready
  blocked_gap
  error
}

/// RC-16 US141 durable market stream checkpoints (ADR-013/014, ADR-018 #25).
/// Semantic progress (sequence/event/occurredAt) is distinct from operational
/// heartbeat time. Future Trading Sessions read, never write, these rows.
model MarketStreamCheckpointRecord {
  workspaceId    String    @map("workspace_id")
  streamId       String    @map("stream_id")
  sourceId       String    @map("source_id")
  instrument     String
  channel        String
  timeframe      String?
  schemaVersion  Int       @default(1) @map("schema_version")
  lastSequence   Int       @map("last_sequence")
  lastEventId    String?   @map("last_event_id")
  lastOccurredAt DateTime? @map("last_occurred_at")
  health         String
  /// Operational liveness only — never semantic progress.
  heartbeatAt    DateTime? @map("heartbeat_at")
  updatedAt      DateTime  @map("updated_at")

  @@id([workspaceId, streamId])
  @@index([workspaceId, sourceId])
  @@map("market_stream_checkpoints")
}

/// RC-16 US142 durable desired subscriptions (ADR-014).
/// Desired state survives process restart — not connector socket memory.
model MarketSubscriptionRecord {
  id          String   @id
  workspaceId String   @map("workspace_id")
  sourceId    String   @map("source_id")
  instrument  String
  channel     String
  streamId    String   @map("stream_id")
  timeframe   String?
  state       String
  updatedAt   DateTime @map("updated_at")

  @@unique([workspaceId, streamId])
  @@index([workspaceId, sourceId, state])
  @@map("market_subscriptions")
}

/// RC-16 ADR-013 consumer checkpoints (US129).
model ConsumerCheckpointRecord {
  consumerId          String                           @map("consumer_id")
  streamId            String                           @map("stream_id")
  consumerVersion     String                           @map("consumer_version")
  workspaceId         String                           @map("workspace_id")
  lastAppliedSequence Int                              @map("last_applied_sequence")
  lastAppliedEventId  String?                          @map("last_applied_event_id")
  status              ConsumerCheckpointDeliveryStatus @default(ready)
  blockedSequence     Int?                             @map("blocked_sequence")
  lastError           String?                          @map("last_error")
  updatedAt           DateTime                         @updatedAt @map("updated_at")

  @@id([consumerId, streamId])
  @@index([workspaceId, consumerId])
  @@map("consumer_checkpoints")
}

/// RC-16 M2 US154 durable paper account.
/// Cash is not authoritative here; openingCapital is an immutable instruction
/// consumed by the append-only Ledger foundation.
model PaperAccount {
  id                         String   @id
  workspaceId                String   @map("workspace_id")
  currency                   String
  mode                       String   @default("paper")
  status                     String
  openingCapital             Decimal  @map("opening_capital") @db.Decimal(38, 18)
  openingLedgerTransactionId String?  @map("opening_ledger_transaction_id")
  idempotencyKey             String   @map("idempotency_key")
  version                    Int      @default(1)
  openedAt                   DateTime @map("opened_at")
  recordedAt                 DateTime @map("recorded_at")

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, status])
  @@map("paper_accounts")
}

/// RC-16 M2 US156/US157 durable Trading Session with fenced lease.
model TradingSession {
  id               String    @id
  workspaceId      String    @map("workspace_id")
  paperAccountId   String    @map("paper_account_id")
  deploymentId     String    @map("deployment_id")
  origin           String
  status           String
  leaseOwnerId     String?   @map("lease_owner_id")
  fencingToken     Int?      @map("fencing_token")
  leaseAcquiredAt  DateTime? @map("lease_acquired_at")
  leaseExpiresAt   DateTime? @map("lease_expires_at")
  leaseHeartbeatAt DateTime? @map("lease_heartbeat_at")
  lastFencingToken Int       @default(0) @map("last_fencing_token")
  version          Int       @default(1)
  failureReason    String?   @map("failure_reason")
  createdAt        DateTime  @map("created_at")
  recordedAt       DateTime  @map("recorded_at")
  actorId          String    @map("actor_id")
  correlationId    String?   @map("correlation_id")
  idempotencyKey   String    @map("idempotency_key")

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, status])
  @@index([workspaceId, paperAccountId])
  @@map("trading_sessions")
}

/// RC-16 M2 US159-US161 durable paper Order aggregate.
model PaperOrder {
  id               String                @id
  workspaceId      String                @map("workspace_id")
  paperAccountId   String                @map("paper_account_id")
  tradingSessionId String                @map("trading_session_id")
  clientOrderId    String                @map("client_order_id")
  intentHash       String                @map("intent_hash")
  idempotencyKey   String                @map("idempotency_key")
  instrument       String
  side             String
  type             String
  quantity         Decimal               @db.Decimal(38, 18)
  limitPrice       Decimal?              @map("limit_price") @db.Decimal(38, 18)
  filledQuantity   Decimal               @default(0) @map("filled_quantity") @db.Decimal(38, 18)
  status           String
  version          Int                   @default(1)
  intent           Json
  riskDecisionId   String?               @map("risk_decision_id")
  riskDecision     Json?                 @map("risk_decision")
  reservationId    String?               @map("reservation_id")
  adapterOrderId   String?               @map("adapter_order_id")
  rejectionReason  String?               @map("rejection_reason")
  createdAt        DateTime              @map("created_at")
  recordedAt       DateTime              @map("recorded_at")
  lifecycle        OrderLifecycleEntry[]

  @@unique([workspaceId, clientOrderId])
  @@unique([workspaceId, idempotencyKey])
  @@unique([workspaceId, intentHash])
  @@index([workspaceId, tradingSessionId, status])
  @@index([workspaceId, paperAccountId])
  @@map("paper_orders")
}

/// Append-only Order lifecycle history owned only by Orders.
model OrderLifecycleEntry {
  id            String     @id @default(cuid())
  orderId       String     @map("order_id")
  workspaceId   String     @map("workspace_id")
  sequence      Int
  fromStatus    String?    @map("from_status")
  toStatus      String     @map("to_status")
  eventType     String     @map("event_type")
  reason        String?
  actorId       String     @map("actor_id")
  correlationId String?    @map("correlation_id")
  occurredAt    DateTime   @map("occurred_at")
  recordedAt    DateTime   @map("recorded_at")
  order         PaperOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, sequence])
  @@index([workspaceId, orderId])
  @@map("order_lifecycle_history")
}

/// Ledger-owned cash balance used by the US162 reservation port.
/// US173 owns creation from append-only Ledger transactions.
model LedgerCashBalance {
  id             String   @id
  workspaceId    String   @map("workspace_id")
  paperAccountId String   @map("paper_account_id")
  currency       String
  postedCash     Decimal  @map("posted_cash") @db.Decimal(38, 18)
  reservedCash   Decimal  @default(0) @map("reserved_cash") @db.Decimal(38, 18)
  version        Int      @default(1)
  updatedAt      DateTime @map("updated_at")

  @@unique([workspaceId, paperAccountId, currency])
  @@index([workspaceId, paperAccountId])
  @@map("ledger_cash_balances")
}

/// Durable, idempotent Ledger-owned Order cash reservation.
model LedgerCashReservation {
  id                    String    @id
  workspaceId           String    @map("workspace_id")
  paperAccountId        String    @map("paper_account_id")
  orderId               String    @map("order_id")
  idempotencyKey        String    @map("idempotency_key")
  releaseIdempotencyKey String?   @map("release_idempotency_key")
  currency              String
  amount                Decimal   @db.Decimal(38, 18)
  status                String
  createdAt             DateTime  @map("created_at")
  releasedAt            DateTime? @map("released_at")

  @@unique([workspaceId, orderId])
  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, paperAccountId, status])
  @@map("ledger_cash_reservations")
}

/// Immutable, explainable M2 baseline pre-trade Risk Decision.
model RiskDecision {
  id            String   @id
  workspaceId   String   @map("workspace_id")
  orderId       String   @map("order_id")
  intentHash    String   @map("intent_hash")
  status        String
  policyId      String   @map("policy_id")
  policyVersion Int      @map("policy_version")
  policyHash    String   @map("policy_hash")
  inputHash     String   @map("input_hash")
  input         Json
  ruleResults   Json     @map("rule_results")
  reasons       Json
  evaluatedAt   DateTime @map("evaluated_at")
  expiresAt     DateTime @map("expires_at")
  recordedAt    DateTime @map("recorded_at")
  actorId       String   @map("actor_id")
  correlationId String?  @map("correlation_id")

  @@unique([workspaceId, orderId, policyHash, inputHash])
  @@index([workspaceId, orderId, status])
  @@index([workspaceId, expiresAt])
  @@map("risk_decisions")
}

/// Immutable, append-only paper Fill recorded only by the Execution Engine (US171).
/// Each Fill references exactly one persisted Order; identity is deterministic so
/// a replayed adapter result maps to the same row and cannot duplicate a Fill.
model PaperFill {
  id                   String   @id
  workspaceId          String   @map("workspace_id")
  orderId              String   @map("order_id")
  paperAccountId       String   @map("paper_account_id")
  tradingSessionId     String   @map("trading_session_id")
  adapterOrderId       String   @map("adapter_order_id")
  adapterFillId        String   @map("adapter_fill_id")
  sequence             Int
  instrument           String
  side                 String
  price                Decimal  @db.Decimal(38, 18)
  quantity             Decimal  @db.Decimal(38, 18)
  grossNotional        Decimal  @map("gross_notional") @db.Decimal(38, 18)
  fee                  Decimal  @db.Decimal(38, 18)
  executionContextHash String   @map("execution_context_hash")
  configurationId      String   @map("configuration_id")
  configurationVersion Int      @map("configuration_version")
  configurationHash    String   @map("configuration_hash")
  occurredAt           DateTime @map("occurred_at")
  recordedAt           DateTime @map("recorded_at")

  @@unique([workspaceId, orderId, sequence])
  @@unique([workspaceId, adapterFillId])
  @@index([workspaceId, orderId])
  @@index([workspaceId, tradingSessionId])
  @@map("paper_fills")
}

/// Rebuildable long-only Position projection derived exclusively from immutable Fills (US172).
model PaperPosition {
  id                      String   @id
  workspaceId             String   @map("workspace_id")
  paperAccountId          String   @map("paper_account_id")
  instrument              String
  side                    String
  quantity                Decimal  @db.Decimal(38, 18)
  averageEntryPrice       Decimal  @map("average_entry_price") @db.Decimal(38, 18)
  costBasis               Decimal  @map("cost_basis") @db.Decimal(38, 18)
  realizedPnl             Decimal  @map("realized_pnl") @db.Decimal(38, 18)
  version                 Int
  lastAppliedFillId       String   @map("last_applied_fill_id")
  lastAppliedFillSequence Int      @map("last_applied_fill_sequence")
  occurredAt              DateTime @map("occurred_at")
  recordedAt              DateTime @map("recorded_at")

  @@unique([workspaceId, paperAccountId, instrument])
  @@index([workspaceId, paperAccountId])
  @@map("paper_positions")
}

/// Append-only balanced financial transaction; Ledger is the financial source of truth (US173).
model LedgerTransaction {
  id                 String        @id
  workspaceId        String        @map("workspace_id")
  paperAccountId     String        @map("paper_account_id")
  idempotencyKey     String        @map("idempotency_key")
  causeType          String        @map("cause_type")
  causeId            String        @map("cause_id")
  currency           String
  occurredAt         DateTime      @map("occurred_at")
  recordedAt         DateTime      @map("recorded_at")
  actorId            String        @map("actor_id")
  correlationId      String?       @map("correlation_id")
  compensationReason String?       @map("compensation_reason")
  entries            LedgerEntry[]

  @@unique([workspaceId, idempotencyKey])
  @@unique([workspaceId, causeType, causeId])
  @@index([workspaceId, paperAccountId, occurredAt])
  @@map("ledger_transactions")
}

/// Immutable Ledger line. Corrections append compensating transactions; rows are never updated.
model LedgerEntry {
  id            String            @id
  transactionId String            @map("transaction_id")
  workspaceId   String            @map("workspace_id")
  line          Int
  account       String
  direction     String
  amount        Decimal           @db.Decimal(38, 18)
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@unique([transactionId, line])
  @@index([workspaceId, account])
  @@map("ledger_entries")
}

/// Versioned mark-to-market projection; never rewrites Position cost accounting (US175).
model PositionValuation {
  id                String   @id
  workspaceId       String   @map("workspace_id")
  paperAccountId    String   @map("paper_account_id")
  positionId        String   @map("position_id")
  instrument        String
  positionVersion   Int      @map("position_version")
  version           Int
  marketStreamId    String   @map("market_stream_id")
  marketEventId     String   @map("market_event_id")
  marketSequence    Int      @map("market_sequence")
  markPrice         Decimal  @map("mark_price") @db.Decimal(38, 18)
  quantity          Decimal  @db.Decimal(38, 18)
  costBasis         Decimal  @map("cost_basis") @db.Decimal(38, 18)
  realizedPnl       Decimal  @map("realized_pnl") @db.Decimal(38, 18)
  marketValue       Decimal  @map("market_value") @db.Decimal(38, 18)
  unrealizedPnl     Decimal  @map("unrealized_pnl") @db.Decimal(38, 18)
  occurredAt        DateTime @map("occurred_at")
  recordedAt        DateTime @map("recorded_at")

  @@unique([workspaceId, positionId])
  @@unique([workspaceId, positionId, marketEventId])
  @@index([workspaceId, paperAccountId])
  @@map("position_valuations")
}

/// Rebuildable account projection sourced only from Ledger and Position valuations (US176).
model PaperPortfolioProjection {
  id                  String   @id
  workspaceId         String   @map("workspace_id")
  paperAccountId      String   @map("paper_account_id")
  currency            String
  availableCash       Decimal  @map("available_cash") @db.Decimal(38, 18)
  reservedCash        Decimal  @map("reserved_cash") @db.Decimal(38, 18)
  cash                Decimal  @db.Decimal(38, 18)
  marketValue         Decimal  @map("market_value") @db.Decimal(38, 18)
  equity              Decimal  @db.Decimal(38, 18)
  realizedPnl         Decimal  @map("realized_pnl") @db.Decimal(38, 18)
  unrealizedPnl       Decimal  @map("unrealized_pnl") @db.Decimal(38, 18)
  totalPnl            Decimal  @map("total_pnl") @db.Decimal(38, 18)
  fees                Decimal  @db.Decimal(38, 18)
  exposure            Decimal  @db.Decimal(38, 18)
  ledgerVersion       Int      @map("ledger_version")
  valuationCheckpoint String   @map("valuation_checkpoint")
  sourceHash          String   @map("source_hash")
  version             Int
  complete            Boolean
  stalePositionIds    Json     @map("stale_position_ids")
  valuedAt            DateTime? @map("valued_at")
  recordedAt          DateTime @map("recorded_at")

  @@unique([workspaceId, paperAccountId])
  @@index([workspaceId, complete])
  @@map("paper_portfolio_projections")
}

/// Durable rebuild comparison and execution-safety checkpoint (US177).
model AccountingReconciliation {
  id               String    @id
  workspaceId      String    @map("workspace_id")
  paperAccountId   String    @map("paper_account_id")
  status           String
  sourceHash       String    @map("source_hash")
  rebuiltHash      String    @map("rebuilt_hash")
  reason           String?
  version          Int
  checkedAt        DateTime  @map("checked_at")
  lastConsistentAt DateTime? @map("last_consistent_at")

  @@unique([workspaceId, paperAccountId])
  @@index([workspaceId, status])
  @@map("accounting_reconciliations")
}

/// Trading Platform portfolio aggregate — single source of financial truth (US204).
/// No exchange connectivity, order execution, or position management.
model Portfolio {
  id           String   @id
  workspaceId  String   @map("workspace_id")
  ownerId      String   @map("owner_id")
  currency     String
  status       String
  cash         Decimal  @db.Decimal(38, 18)
  initialCash  Decimal  @map("initial_cash") @db.Decimal(38, 18)
  realizedPnl  Decimal  @map("realized_pnl") @db.Decimal(38, 18)
  unrealizedPnl Decimal @map("unrealized_pnl") @db.Decimal(38, 18)
  usedMargin   Decimal  @map("used_margin") @db.Decimal(38, 18)
  createdAt    DateTime @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  snapshots     PortfolioSnapshot[]
  events        PortfolioEvent[]
  positions     Position[]
  orders        Order[]
  riskDecisions TradingRiskDecision[]
  riskPolicies  TradingRiskPolicy[]
  paperSession  PaperSession?
  liveSession   LiveSession?

  @@unique([workspaceId])
  @@index([ownerId, status])
  @@index([workspaceId, status])
  @@map("portfolios")
}

/// Trading Platform position aggregate — single source of truth for open/closed positions (US205).
/// No exchange connectivity, order execution, or strategy concerns.
model Position {
  id                String    @id
  portfolioId       String    @map("portfolio_id")
  symbol            String
  side              String
  status            String
  quantity          Decimal   @db.Decimal(38, 18)
  entryPrice        Decimal   @map("entry_price") @db.Decimal(38, 18)
  markPrice         Decimal   @map("mark_price") @db.Decimal(38, 18)
  averageEntryPrice Decimal   @map("average_entry_price") @db.Decimal(38, 18)
  realizedPnl       Decimal   @map("realized_pnl") @db.Decimal(38, 18)
  unrealizedPnl     Decimal   @map("unrealized_pnl") @db.Decimal(38, 18)
  createdAt         DateTime  @map("created_at")
  updatedAt         DateTime  @map("updated_at")
  closedAt          DateTime? @map("closed_at")

  portfolio Portfolio         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  history   PositionHistory[]
  events    PositionEvent[]

  @@index([portfolioId, status])
  @@index([portfolioId, symbol])
  @@index([portfolioId, createdAt])
  @@map("trading_positions")
}

/// Immutable position lifecycle history entries (US205).
model PositionHistory {
  id          String   @id
  positionId  String   @map("position_id")
  timestamp   DateTime
  action      String
  quantity    Decimal  @db.Decimal(38, 18)
  price       Decimal  @db.Decimal(38, 18)
  realizedPnl Decimal  @map("realized_pnl") @db.Decimal(38, 18)
  createdAt   DateTime @default(now()) @map("created_at")

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId, timestamp])
  @@map("position_history")
}

/// Durable position domain events (US205).
model PositionEvent {
  id         String   @id
  positionId String   @map("position_id")
  eventType  String   @map("event_type")
  payload    Json
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("position_events")
}

/// Immutable portfolio financial snapshot (US204).
model PortfolioSnapshot {
  id            String   @id
  portfolioId   String   @map("portfolio_id")
  timestamp     DateTime
  cash          Decimal  @db.Decimal(38, 18)
  equity        Decimal  @db.Decimal(38, 18)
  usedMargin    Decimal  @map("used_margin") @db.Decimal(38, 18)
  availableMargin Decimal @map("available_margin") @db.Decimal(38, 18)
  realizedPnl   Decimal  @map("realized_pnl") @db.Decimal(38, 18)
  unrealizedPnl Decimal  @map("unrealized_pnl") @db.Decimal(38, 18)
  createdAt     DateTime @default(now()) @map("created_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, timestamp])
  @@map("portfolio_snapshots")
}

/// Durable portfolio domain events (US204).
model PortfolioEvent {
  id          String   @id
  portfolioId String   @map("portfolio_id")
  eventType   String   @map("event_type")
  payload     Json
  occurredAt  DateTime @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("portfolio_events")
}

/// Trading Platform order aggregate — single source of truth for order lifecycle (US206).
/// No exchange connectivity or live execution.
model Order {
  id                String    @id
  portfolioId       String    @map("portfolio_id")
  positionId        String?   @map("position_id")
  symbol            String
  side              String
  type              String
  quantity          Decimal   @db.Decimal(38, 18)
  requestedPrice    Decimal?  @map("requested_price") @db.Decimal(38, 18)
  executedPrice     Decimal?  @map("executed_price") @db.Decimal(38, 18)
  filledQuantity    Decimal   @map("filled_quantity") @db.Decimal(38, 18)
  remainingQuantity Decimal   @map("remaining_quantity") @db.Decimal(38, 18)
  status            String
  timeInForce       String    @map("time_in_force")
  createdAt         DateTime  @map("created_at")
  updatedAt         DateTime  @map("updated_at")
  executedAt        DateTime? @map("executed_at")
  cancelledAt       DateTime? @map("cancelled_at")

  portfolio Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  fills     OrderFill[]
  history   OrderHistory[]
  events    OrderEvent[]

  @@index([portfolioId, status])
  @@index([portfolioId, symbol])
  @@index([portfolioId, createdAt])
  @@map("trading_orders")
}

/// Immutable order fill records (US206).
model OrderFill {
  id        String   @id
  orderId   String   @map("order_id")
  timestamp DateTime
  quantity  Decimal  @db.Decimal(38, 18)
  price     Decimal  @db.Decimal(38, 18)
  fee       Decimal  @db.Decimal(38, 18)
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, timestamp])
  @@map("order_fills")
}

/// Immutable order status transition history (US206).
model OrderHistory {
  id             String   @id
  orderId        String   @map("order_id")
  timestamp      DateTime
  previousStatus String   @map("previous_status")
  currentStatus  String   @map("current_status")
  reason         String
  createdAt      DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, timestamp])
  @@map("order_history")
}

/// Durable order domain events (US206).
model OrderEvent {
  id         String   @id
  orderId    String   @map("order_id")
  eventType  String   @map("event_type")
  payload    Json
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("order_events")
}

/// Trading Platform risk decision aggregate — immutable gatekeeper result (US207).
/// Distinct from paper RiskDecision (`risk_decisions`). No exchange / execution.
model TradingRiskDecision {
  id          String   @id
  portfolioId String   @map("portfolio_id")
  orderId     String   @map("order_id")
  decision    String
  reason      String
  score       String
  timestamp   DateTime
  createdAt   DateTime @default(now()) @map("created_at")

  portfolio Portfolio           @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  events    TradingRiskEvent[]

  @@index([portfolioId, timestamp])
  @@index([orderId])
  @@index([portfolioId, decision])
  @@map("trading_risk_decisions")
}

/// Configurable risk policy (US207).
model TradingRiskPolicy {
  id            String   @id
  portfolioId   String?  @map("portfolio_id")
  name          String
  enabled       Boolean  @default(true)
  priority      Int
  configuration Json
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, name])
  @@index([enabled, priority])
  @@map("trading_risk_policies")
}

/// Durable risk domain events (US207).
model TradingRiskEvent {
  id         String   @id
  decisionId String?  @map("decision_id")
  eventType  String   @map("event_type")
  payload    Json
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  decision TradingRiskDecision? @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("trading_risk_events")
}

/// Trading Platform paper trading session — orchestration aggregate (US208).
/// Owns exactly one Portfolio; does not duplicate Portfolio/Position/Order/Risk logic.
model PaperSession {
  id                    String    @id
  workspaceId           String    @map("workspace_id")
  ownerId               String    @map("owner_id")
  portfolioId           String    @unique @map("portfolio_id")
  portfolioWorkspaceKey String    @unique @map("portfolio_workspace_key")
  name                  String
  status                String
  initialBalance        Decimal   @map("initial_balance") @db.Decimal(38, 18)
  currentBalance        Decimal   @map("current_balance") @db.Decimal(38, 18)
  createdAt             DateTime  @map("created_at")
  startedAt             DateTime? @map("started_at")
  finishedAt            DateTime? @map("finished_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  portfolio  Portfolio        @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  executions PaperExecution[]
  events     PaperEvent[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([ownerId, status])
  @@map("paper_trading_sessions")
}

/// Immutable paper trade execution record (US208).
model PaperExecution {
  id             String   @id
  sessionId      String   @map("session_id")
  orderId        String   @map("order_id")
  executionTime  DateTime @map("execution_time")
  executionPrice Decimal  @map("execution_price") @db.Decimal(38, 18)
  slippage       Decimal  @db.Decimal(38, 18)
  commission     Decimal  @db.Decimal(38, 18)
  createdAt      DateTime @default(now()) @map("created_at")

  session PaperSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, executionTime])
  @@index([orderId])
  @@map("paper_trading_executions")
}

/// Immutable paper trading domain events (US208).
model PaperEvent {
  id        String   @id
  sessionId String   @map("session_id")
  type      String
  timestamp DateTime
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  session PaperSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([type, timestamp])
  @@map("paper_trading_events")
}

/// Exchange connection state for the Exchange Adapter Layer (US209).
/// Infrastructure boundary only — never mutates Portfolio / Position / Order / Risk.
model ExchangeConnection {
  id                 String    @id
  workspaceId        String    @map("workspace_id")
  exchangeId         String    @map("exchange_id")
  status             String
  latencyMs          Int?      @map("latency_ms")
  lastHeartbeatAt    DateTime? @map("last_heartbeat_at")
  lastSynchronizedAt DateTime? @map("last_synchronized_at")
  apiPermissions     Json      @map("api_permissions")
  supportedMarkets   Json      @map("supported_markets")
  capabilities       Json
  createdAt          DateTime  @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  events ExchangeEvent[]

  @@unique([workspaceId, exchangeId])
  @@index([workspaceId, status])
  @@index([exchangeId, status])
  @@map("exchange_connections")
}

/// Durable exchange adapter events (US209). Adapters emit events only.
model ExchangeEvent {
  id           String   @id
  connectionId String   @map("connection_id")
  eventType    String   @map("event_type")
  payload      Json
  occurredAt   DateTime @map("occurred_at")
  createdAt    DateTime @default(now()) @map("created_at")

  connection ExchangeConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("exchange_events")
}

/// Live trading session aggregate — operational orchestration over Trading Core + Exchange Adapter (US210).
/// No portfolio/position/risk business logic; coordinates existing engines only.
model LiveSession {
  id                    String    @id
  workspaceId           String    @map("workspace_id")
  ownerId               String    @map("owner_id")
  portfolioId           String    @unique @map("portfolio_id")
  portfolioWorkspaceKey String    @unique @map("portfolio_workspace_key")
  exchange              String
  accountId             String    @map("account_id")
  status                String
  startedAt             DateTime? @map("started_at")
  stoppedAt             DateTime? @map("stopped_at")
  lastHeartbeat         DateTime? @map("last_heartbeat")
  reconnectCount        Int       @default(0) @map("reconnect_count")
  synchronizationState  String    @map("synchronization_state")
  tradingFrozen         Boolean   @default(false) @map("trading_frozen")
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  portfolio            Portfolio             @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  events               LiveEvent[]
  synchronizationLogs  SynchronizationLog[]
  processedExecutions  LiveProcessedExecution[]

  @@index([workspaceId, status])
  @@index([workspaceId, accountId, status])
  @@index([ownerId, status])
  @@index([exchange, status])
  @@map("live_trading_sessions")
}

/// Immutable live trading domain events (US210).
model LiveEvent {
  id        String   @id
  sessionId String   @map("session_id")
  type      String
  timestamp DateTime
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([type, timestamp])
  @@map("live_trading_events")
}

/// Synchronization and recovery operation log (US210).
model SynchronizationLog {
  id          String    @id
  sessionId   String    @map("session_id")
  kind        String
  status      String
  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")
  details     Json
  createdAt   DateTime  @default(now()) @map("created_at")

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, startedAt])
  @@index([kind, status])
  @@map("live_trading_synchronization_logs")
}

/// Deduplication store for exchange execution IDs applied to Trading Core (US210).
model LiveProcessedExecution {
  id          String   @id
  sessionId   String   @map("session_id")
  executionId String   @map("execution_id")
  createdAt   DateTime @default(now()) @map("created_at")

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, executionId])
  @@index([sessionId])
  @@map("live_trading_processed_executions")
}
